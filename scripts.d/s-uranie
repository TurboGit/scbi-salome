
function s-uranie-archive()
{
    local VERSION=$1

    echo default
    echo none
    echo wget
    echo https://uranie.cea.fr/tarball
    echo URANIE-$VERSION-Source.tar.gz
}

function s-uranie-build-depends()
{
    echo s-cmake
    echo os@-xml2-utils
}

function s-uranie-depends()
{
    echo s-root
    echo os@-python3
    echo os@-python3-dev
    echo os@-boost-dev
}

function s-uranie-env()
{
    local PREFIX=$1
    local TARGET=$2

    add-to-var CMAKE_PREFIX_PATH $PREFIX/lib/cmake
    add-to-var LD_LIBRARY_PATH   $PREFIX/lib
    add-to-var PYTHONPATH        \
               $PREFIX/lib/python$PYTHON_VERSION/site-packages
}

function s-uranie-config-options()
{
    local PREFIX=$1
    local TARGET=$2
    local VARIANT=$3

    echo -DCMAKE_INSTALL_PREFIX=$PREFIX
    echo -DLOCAL_PYTHON_EXEC=$(command -v python$PYTHON_VERSION)
    echo -DPython_EXECUTABLE=$(command -v python$PYTHON_VERSION)
    echo -DPython3_EXECUTABLE=$(command -v python$PYTHON_VERSION)
}

function s-uranie-config()
{
    local PREFIX=$1
    local TARGET=$2

    local OPTIONS=()
    get-config-options OPTIONS $PREFIX $TARGET $VARIANT

    cmake "${OPTIONS[@]}" ../src
}

function s-uranie-build()
{
    local PREFIX=$1
    local TARGET=$2

    make -j$SCBI_JOBS
}

function s-uranie-install()
{
    local PREFIX=$1
    local TARGET=$2

    make install
}

function s-uranie-post-install()
{
    local PREFIX=$1
    local TARGET=$2
    local VARIANT=$3

    [[ -d "$PREFIX"/lib/python/URANIE ]] &&
        {
            mkdir -p "$PREFIX"/lib/python${PYTHON_VERSION}/site-packages
            mv "$PREFIX"/lib/python/URANIE "$PREFIX"/lib/python${PYTHON_VERSION}/site-packages
            rmdir "$PREFIX"/lib/python
        }
}

function s-uranie-prefix()
{
    echo NONE
}
