
inherit-plugin --name handle-dist s-python-post-install-dist-packages

with-variant native os@-pyqt-sip:[v]

function s-pyqt-sip-archive()
{
    local VERSION=$1

    echo default
    echo none
    echo wget
    echo ftp://ftp.cea.fr/pub/salome/prerequisites
    echo PyQt5_sip-$VERSION.tar.gz
}

function s-pyqt-sip-patches()
{
    local PREFIX=$1
    local TARGET=$2
    local VARIANT=$3
    local KIND=$4
    local REF=$5

    [[ $REF =~ 12.8 ]] &&
        {
            echo pyqtsip-12.8-f_back.patch
        }
}

function s-pyqt-sip-env()
{
    local PREFIX=$1
    local TARGET=$2

    set-var    PYQT_SIPS_DIR $PREFIX

    add-to-var C_INCLUDE_PATH \
               $PREFIX/include
    add-to-var CPLUS_INCLUDE_PATH \
               $PREFIX/include
    add-to-var PYTHONPATH \
               $PREFIX/lib/python$PYTHON_VERSION/site-packages
}

function s-pyqt-sip-build-env()
{
    local PREFIX=$1
    local TARGET=$2

    add-to-var PYTHONPATH $PREFIX/lib/python$PYTHON_VERSION/site-packages
}

function s-pyqt-sip-out-of-tree()
{
    echo false
}

function s-pyqt-sip-pre-install()
{
    local PREFIX=$1
    local TARGET=$2

    mkdir -p $PREFIX/lib/python$PYTHON_VERSION/site-packages
}

function s-pyqt-sip-install()
{
    local PREFIX=$1
    local TARGET=$2

    CFLAGS='-fpermissive -Wno-implicit-function-declaration -Wno-deprecated-declarations -Wno-int-conversion -fno-strict-overflow -Wsign-compare -DNDEBUG -g -O2' \
          pip3 install --ignore-installed \
          . --no-deps --prefix=$PREFIX
}

function s-pyqt-sip-post-install()
{
    local PREFIX=$1
    local TARGET=$2

    handle-dist-post-install $PREFIX $TARGET

    #  Copy headers

    mkdir -p $PREFIX/include
    cp *.h $PREFIX/include
}

function s-pyqt-sip-prefix()
{
    echo NONE
}
