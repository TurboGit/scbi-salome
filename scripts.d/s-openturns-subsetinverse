
function s-openturns-subsetinverse-vcs()
{
    echo default
    echo none
    echo git
    echo https://github.com/openturns/otsubsetinverse.git
}

function s-openturns-subsetinverse-build-depends()
{
    echo os@-python3-sphinx

    echo s-cmake
    echo s-swig
}

function s-openturns-subsetinverse-depends()
{
    echo os@-python3

    echo s-openturns
}

function s-openturns-subsetinverse-env()
{
    local PREFIX=$1
    local TARGET=$2

    set-var OTSUBSETINVERSE_HOME $PREFIX

    add-to-var LD_LIBRARY_PATH   $PREFIX/lib
    add-to-var PYTHONPATH        \
               $PREFIX/lib/python$PYTHON_VERSION/site-packages/
}

function s-openturns-subsetinverse-config-options()
{
    local PREFIX=$1
    local TARGET=$2
    local VARIANT=$3

    echo -DCMAKE_INSTALL_PREFIX=$PREFIX
    echo -DPython_EXECUTABLE=$(command -v python$PYTHON_VERSION)
    echo -DPython3_EXECUTABLE=$(command -v python$PYTHON_VERSION)
    echo -DCMAKE_FIND_ROOT_PATH=ON
    echo -DSWIG_DIR:FILEPATH=$(swig -swiglib)
    echo -DSWIG_EXECUTABLE:PATH=$(command -v swig)
    echo -DCMAKE_SKIP_INSTALL_RPATH:BOOL=ON
    echo -DUSE_SPHINX=OFF
}

function s-openturns-subsetinverse-config()
{
    local PREFIX=$1
    local TARGET=$2

    local OPTIONS=()
    get-config-options OPTIONS $PREFIX $TARGET $VARIANT

    cmake "${OPTIONS[@]}" ../src
}

function s-openturns-subsetinverse-build()
{
    local PREFIX=$1
    local TARGET=$2

    make -j$SCBI_JOBS
}

function s-openturns-subsetinverse-install()
{
    local PREFIX=$1
    local TARGET=$2

    make install
}

function s-openturns-subsetinverse-prefix()
{
    echo NONE
}
