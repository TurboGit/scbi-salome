
function s-salome-adao-vcs()
{
    echo default
    echo none
    echo git
    echo https://github.com/SalomePlatform/adao
}

function s-salome-adao-salome-module()
{
    echo ADAO
}

function s-salome-adao-build-depends()
{
    echo s-cmake
    echo os@-sphinx-common
    # Needed only to get the ADAO version
    echo s-adao-tool
}

function s-salome-adao-common-depends()
{
    echo s-salome-configuration
}

function s-salome-adao-default-depends()
{
    echo os@-python3-docutils

    echo s-salome-configuration
    echo s-salome-kernel
    echo s-salome-eficas
    echo s-eficas-tools
    echo s-yacs
    echo s-omniorb
    echo s-python3-nlopt
}

function s-salome-adao-env()
{
    local PREFIX=$1
    local TARGET=$2

    set-var    ADAO_ROOT_DIR   $PREFIX

    add-to-var LD_LIBRARY_PATH $PREFIX/lib/salome
    add-to-var PYTHONPATH \
               $PREFIX/lib/python$PYTHON_VERSION/site-packages

    add-to-var SALOME_MODULES  ADAO
    add-to-var SalomeAppConfig $PREFIX/share/salome/resources/adao
}

function s-salome-adao-build-env()
{
    local PREFIX=$1
    local TARGET=$2

    set-var CURRENT_SOFTWARE_INSTALL_DIR $PREFIX
}

function s-salome-adao-common-config-options()
{
    local PREFIX=$1
    local TARGET=$2
    local VARIANT=$3

    local PSP=lib/python$PYTHON_VERSION/site-packages
    local INI=$PSP/salome/adao/daCore/__init__.py

    echo -DCMAKE_INSTALL_PREFIX=$PREFIX
    echo -DADAO_PYTHON_MODULE=OFF


    echo -DCMAKE_BUILD_TYPE=$(get-build-type CMAKE Release)
    echo -DCMAKE_PREFIX_PATH=$SCBI_BDIR/install
    echo -DPython_EXECUTABLE=$(command -v python$PYTHON_VERSION)
    echo -DPython3_EXECUTABLE=$(command -v python$PYTHON_VERSION)
    echo -DKERNEL_ROOT_DIR=$KERNEL_ROOT_DIR
    echo -DEFICAS_ROOT_DIR=$EFICAS_TOOLS_ROOT_DIR
    echo -DADAO_PYTHON_ROOT_DIR=$PREFIX
    echo -DFILE_OF_ADAO_PYTHON_MODULE=$PREFIX/daComposant/$PSP/$INI
    echo -DADAO_SALOME_MODULE=ON
}

function s-salome-adao-config()
{
    local PREFIX=$1
    local TARGET=$2
    local VARIANT=$3

    local OPTIONS=()
    get-config-options OPTIONS $PREFIX $TARGET $VARIANT

    cmake "${OPTIONS[@]}" ../src
}

function s-salome-adao-build()
{
    local PREFIX=$1
    local TARGET=$2

    make -j$SCBI_JOBS
}

function s-salome-adao-install()
{
    local PREFIX=$1
    local TARGET=$2

    make install
}

function s-salome-adao-prefix()
{
    echo NONE
}
