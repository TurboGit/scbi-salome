
function s-openturns-fftw-vcs()
{
    echo default
    echo none
    echo git
    echo https://github.com/openturns/otfftw.git
}

function s-openturns-fftw-build-depends()
{
    echo os@-python3-sphinx

    echo s-cmake
    echo s-swig
}

function s-openturns-fftw-depends()
{
    echo os@-python3
    echo os@-fftw3-dev

    echo s-openturns
}

function s-openturns-fftw-env()
{
    local PREFIX=$1
    local TARGET=$2

    set-var    OTFFTW_HOME     $PREFIX

    add-to-var LD_LIBRARY_PATH $PREFIX/lib
    add-to-var PYTHONPATH      \
               $PREFIX/lib/python$PYTHON_VERSION/site-packages/
}

function s-openturns-fftw-config-options()
{
    local PREFIX=$1
    local TARGET=$2
    local VARIANT=$3

    echo -DCMAKE_INSTALL_PREFIX=$PREFIX
    echo -DPython_EXECUTABLE=$(command -v python$PYTHON_VERSION)
    echo -DPython3_EXECUTABLE=$(command -v python$PYTHON_VERSION)
    echo -DCMAKE_FIND_ROOT_PATH=ON
    echo -DSWIG_DIR:FILEPATH=$(swig -swiglib)
    echo -DSWIG_EXECUTABLE:PATH=$(command -v swig)
    echo -DCMAKE_SKIP_INSTALL_RPATH:BOOL=ON
    echo -DBUILD_DOC=OFF
}


function s-openturns-fftw-config()
{
    local PREFIX=$1
    local TARGET=$2

    local OPTIONS=()
    get-config-options OPTIONS $PREFIX $TARGET $VARIANT

    cmake "${OPTIONS[@]}" ../src
}

function s-openturns-fftw-build()
{
    local PREFIX=$1
    local TARGET=$2

    make -j$SCBI_JOBS
}

function s-openturns-fftw-install()
{
    local PREFIX=$1
    local TARGET=$2

    make install
}

function s-openturns-fftw-prefix()
{
    echo NONE
}
